---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="es" class="bg-gray-900 text-gray-100">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
        
        <script src="https://cdn.tailwindcss.com"></script>
	</head>
	<body class="min-h-screen flex flex-col font-sans selection:bg-red-600 selection:text-white">
        <header class="bg-black border-b-2 border-red-600 p-4 sticky top-0 z-10 shadow-lg">
            <div class="max-w-6xl mx-auto flex justify-between items-center">
                <a href="/" class="text-3xl font-black italic tracking-tighter text-white">
                    TAKA<span class="text-red-600">SPORT</span>
                </a>
            </div>
        </header>

        <main class="flex-grow">
			<slot />
		</main>

        <footer class="bg-black text-gray-500 text-center p-8 border-t border-gray-800 mt-12">
            <p class="font-bold text-lg mb-2 italic">Taka Sport</p>
            <p class="text-sm">&copy; {new Date().getFullYear()} Medio Deportivo Internacional. Todos los derechos reservados.</p>
        </footer>
	</body>
</html>