---
interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: string;
	url?: string;
}

const { 
	title, 
	description = "La actualidad deportiva mundial, filtrada y validada por nuestro panel de expertos.",
	image = "https://taka-sport-web.vercel.app/default-social.jpg",
	type = "website",
	url = "https://taka-sport-web.vercel.app/"
} = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={url} />

		<meta property="og:type" content={type} />
		<meta property="og:url" content={url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<style is:global>
			:root {
				--bg-dark: #111827;
				--bg-card: #1f2937;
				--text-main: #f3f4f6;
				--text-muted: #9ca3af;
				--accent-red: #dc2626;
				--accent-hover: #ef4444;
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				background-color: var(--bg-dark);
				color: var(--text-main);
				line-height: 1.5;
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			a { text-decoration: none; color: inherit; }
			
			header {
				background-color: #000;
				border-bottom: 2px solid var(--accent-red);
				padding: 1rem;
				position: sticky;
				top: 0;
				z-index: 10;
			}
			.logo { font-size: 1.875rem; font-weight: 900; font-style: italic; letter-spacing: -0.05em; display: inline-block; }
			.logo-red { color: var(--accent-red); }
            
            /* ESTILOS NUEVOS: BARRA DE NAVEGACIÓN */
            .top-bar { display: flex; flex-direction: column; gap: 1rem; }
            @media (min-width: 768px) {
                .top-bar { flex-direction: row; justify-content: space-between; align-items: center; }
            }
            .nav-menu { display: flex; gap: 1.5rem; overflow-x: auto; padding-bottom: 0.5rem; scrollbar-width: none; }
            .nav-menu::-webkit-scrollbar { display: none; }
            .nav-item {
                color: var(--text-muted);
                font-weight: bold;
                text-transform: uppercase;
                font-size: 0.85rem;
                letter-spacing: 0.05em;
                white-space: nowrap;
                transition: color 0.2s;
            }
            .nav-item:hover { color: var(--accent-red); }
			
			main { flex-grow: 1; width: 100%; max-width: 1152px; margin: 0 auto; padding: 2rem 1rem; }
			
			footer {
				background-color: #000;
				color: var(--text-muted);
				text-align: center;
				padding: 2rem;
				margin-top: 3rem;
				border-top: 1px solid #374151;
			}
			.footer-brand { font-weight: bold; font-size: 1.125rem; margin-bottom: 0.5rem; font-style: italic; }
		</style>
	</head>
	<body>
		<header>
			<div style="max-width: 1152px; margin: 0 auto;" class="top-bar">
				<a href="/" class="logo">TAKA<span class="logo-red">SPORT</span></a>
                
                <nav class="nav-menu">
                    <a href="/?tag=Fútbol" class="nav-item">Fútbol</a>
                    <a href="/?tag=Tenis" class="nav-item">Tenis</a>
                    <a href="/?tag=Baloncesto" class="nav-item">Baloncesto</a>
                    <a href="/?tag=F1" class="nav-item">F1</a>
                    <a href="/?tag=MotoGP" class="nav-item">MotoGP</a>
                    <a href="/?tag=Polideportivo" class="nav-item">Más Deportes</a>
                </nav>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer>
			<p class="footer-brand">Taka Sport</p>
			<p style="font-size: 0.875rem;">&copy; {new Date().getFullYear()} Medio Deportivo Internacional. Todos los derechos reservados.</p>
		</footer>
	</body>
</html>