---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style is:global>
			/* COLORES Y VARIABLES GLOBALES */
			:root {
				--bg-dark: #111827;
				--bg-card: #1f2937;
				--text-main: #f3f4f6;
				--text-muted: #9ca3af;
				--accent-red: #dc2626;
				--accent-hover: #ef4444;
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				background-color: var(--bg-dark);
				color: var(--text-main);
				line-height: 1.5;
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			a { text-decoration: none; color: inherit; }
			
			/* CABECERA (HEADER) */
			header {
				background-color: #000;
				border-bottom: 2px solid var(--accent-red);
				padding: 1rem;
				position: sticky;
				top: 0;
				z-index: 10;
			}
			.logo { font-size: 1.875rem; font-weight: 900; font-style: italic; letter-spacing: -0.05em; }
			.logo-red { color: var(--accent-red); }
			
			/* CUERPO (MAIN) */
			main { flex-grow: 1; width: 100%; max-width: 1152px; margin: 0 auto; padding: 2rem 1rem; }
			
			/* PIE DE PÁGINA (FOOTER) */
			footer {
				background-color: #000;
				color: var(--text-muted);
				text-align: center;
				padding: 2rem;
				margin-top: 3rem;
				border-top: 1px solid #374151;
			}
			.footer-brand { font-weight: bold; font-size: 1.125rem; margin-bottom: 0.5rem; font-style: italic; }
		</style>
	</head>
	<body>
		<header>
			<div style="max-width: 1152px; margin: 0 auto;">
				<a href="/" class="logo">TAKA<span class="logo-red">SPORT</span></a>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer>
			<p class="footer-brand">Taka Sport</p>
			<p style="font-size: 0.875rem;">&copy; {new Date().getFullYear()} Medio Deportivo Internacional. Todos los derechos reservados.</p>
		</footer>
	</body>
</html>