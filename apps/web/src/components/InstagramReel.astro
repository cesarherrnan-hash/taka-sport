---
interface Props {
  url: string;
  isFeatured?: boolean;
}

const { url, isFeatured = false } = Astro.props;
const match = url.match(/(?:p|reel|tv)\/([a-zA-Z0-9_-]+)/);
const shortcode = match ? match[1] : '';
const embedUrl = shortcode ? `https://www.instagram.com/p/${shortcode}/embed/captioned/` : '';
---

<div class={`reel-container ${isFeatured ? 'featured' : 'carousel-item'}`}>
    {embedUrl ? (
        <iframe 
            src={embedUrl}
            class="ig-iframe"
            frameborder="0" 
            scrolling="no" 
            allowtransparency="true"
            allow="encrypted-media"
            loading="lazy"
        ></iframe>
    ) : (
        <div class="error">Video no disponible</div>
    )}
</div>

<style>
    .reel-container {
        background-color: #000;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #374151;
        flex-shrink: 0; /* Importante para el carrusel */
    }

    .carousel-item {
        width: 280px; /* Tamaño ideal para fila horizontal */
        height: 450px;
    }

    .featured {
        width: 100%;
        height: 600px;
    }

    .ig-iframe {
        width: 100%;
        height: 100%;
        border: none;
    }

    .error {
        color: #666;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        font-size: 0.8rem;
    }
</style>