---
interface ReelData {
  link: string;
  image: string;
  title: string;
}

interface Props {
  reels: ReelData[];
}

const { reels } = Astro.props;
---

<div class="reels-carousel">
    {reels.map(reel => (
        <a href={reel.link} target="_blank" class="reel-card" title={`Ver: ${reel.title}`}>
            <div class="reel-thumb" style={`background-image: url('${reel.image}')`}>
                <div class="play-overlay">
                    <svg viewBox="0 0 24 24" fill="white" width="60" height="60"><path d="M8 5.14v14l11-7-11-7z"/></svg>
                </div>
            </div>
            <div class="reel-info">
                <span>{reel.title}</span>
            </div>
        </a>
    ))}
</div>

<style>
    .reels-carousel {
        display: flex;
        gap: 1.25rem;
        overflow-x: auto;
        padding-bottom: 1.5rem;
        scrollbar-width: thin;
        scrollbar-color: var(--accent-red) transparent;
    }
    .reels-carousel::-webkit-scrollbar { height: 6px; }
    .reels-carousel::-webkit-scrollbar-thumb { background: var(--accent-red); border-radius: 10px; }

    .reel-card {
        flex: 0 0 260px; /* Ancho de cada miniatura */
        background: var(--bg-card);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #374151;
        transition: transform 0.3s, border-color 0.3s;
        text-decoration: none;
        display: flex;
        flex-direction: column;
    }
    .reel-card:hover { transform: translateY(-5px); border-color: var(--accent-red); }

    .reel-thumb {
        height: 400px; /* Alto de la miniatura (formato vertical de Reel) */
        background-size: cover;
        background-position: center;
        position: relative;
    }
    .play-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s;
    }
    .reel-card:hover .play-overlay { opacity: 1; }

    .reel-info {
        padding: 12px 16px;
        background: #000;
        color: white;
        font-size: 0.85rem;
        font-weight: bold;
        text-transform: uppercase;
        text-align: center;
        border-top: 2px solid var(--accent-red);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>