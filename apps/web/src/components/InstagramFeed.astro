---
interface Props {
  reels: any[];
}

const { reels } = Astro.props;
---

<div class="reels-carousel">
    {reels.map(reel => (
        <a href={reel.post_url} target="_blank" class="reel-card">
            <div class="reel-thumb" style={`background-image: url('${reel.thumbnail_url}')`}>
                <div class="play-overlay">
                    <svg viewBox="0 0 24 24" fill="white" width="48" height="48"><path d="M8 5.14v14l11-7-11-7z"/></svg>
                </div>
            </div>
            <div class="reel-info">
                <span>{reel.title || 'Ver Reel'}</span>
            </div>
        </a>
    ))}
</div>

<style>
    .reels-carousel {
        display: flex;
        gap: 1.25rem;
        overflow-x: auto;
        padding-bottom: 1.5rem;
        scrollbar-width: thin;
        scrollbar-color: var(--accent-red) transparent;
    }
    .reels-carousel::-webkit-scrollbar { height: 6px; }
    .reels-carousel::-webkit-scrollbar-thumb { background: var(--accent-red); border-radius: 10px; }

    .reel-card {
        flex: 0 0 240px;
        background: var(--bg-card);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #374151;
        transition: transform 0.3s;
        text-decoration: none;
    }
    .reel-card:hover { transform: translateY(-5px); border-color: var(--accent-red); }

    .reel-thumb {
        height: 350px;
        background-size: cover;
        background-position: center;
        position: relative;
    }
    .play-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s;
    }
    .reel-card:hover .play-overlay { opacity: 1; }

    .reel-info {
        padding: 12px;
        background: #000;
        color: white;
        font-size: 0.75rem;
        font-weight: bold;
        text-transform: uppercase;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>