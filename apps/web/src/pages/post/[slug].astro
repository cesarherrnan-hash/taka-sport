---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;

const { data: post, error } = await supabase
  .from('editorial_drafts')
  .select('*')
  .eq('slug', slug)
  .single();

if (error || !post) {
  return Astro.redirect('/404');
}

const contentRaw = post.content;
const bodyText = contentRaw.split('CUERPO:')[1] || contentRaw;

// Construimos la URL completa para el SEO
const articleUrl = `https://taka-sport-web.vercel.app/post/${post.slug}`;

// Schema.org estructurado para Google News / Discover
const schema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": post.title,
  "description": post.seo_description,
  "datePublished": post.published_at,
  "author": [{
      "@type": "Organization",
      "name": "Taka Sport",
      "url": "https://taka-sport-web.vercel.app/"
  }]
};
---

<Layout 
	title={`${post.title} | Taka Sport`}
	description={post.seo_description}
	type="article"
	url={articleUrl}
>
	<script type="application/ld+json" set:html={JSON.stringify(schema)} />

	<style>
		.article-container { max-width: 800px; margin: 0 auto; }
		.back-link { display: inline-block; color: var(--accent-red); font-weight: bold; text-transform: uppercase; font-size: 0.875rem; margin-bottom: 2rem; transition: color 0.2s; }
		.back-link:hover { color: var(--accent-hover); }
		
		.article-header { margin-bottom: 3rem; }
		.article-title { font-size: 2.5rem; font-weight: 900; line-height: 1.1; margin-bottom: 1.5rem; }
		.article-bajada { font-size: 1.25rem; color: var(--text-muted); font-style: italic; border-left: 4px solid var(--accent-red); padding-left: 1rem; }
		
		.article-body { font-size: 1.125rem; color: #d1d5db; line-height: 1.8; white-space: pre-line; }
		
		.article-footer {
			margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #374151;
			display: flex; justify-content: space-between; color: var(--text-muted); font-size: 0.875rem;
		}
		.brand-tag { text-transform: uppercase; font-weight: bold; letter-spacing: 0.05em; color: #6b7280; }
		
		@media (min-width: 768px) {
			.article-title { font-size: 3.5rem; }
		}
	</style>

	<article class="article-container">
		<a href="/" class="back-link">← Volver a la Portada</a>
		
		<header class="article-header">
			<h1 class="article-title">{post.title}</h1>
			<p class="article-bajada">{post.seo_description}</p>
		</header>
		
		<div class="article-body">
			{bodyText}
		</div>

		<footer class="article-footer">
			<span>Publicado el {new Date(post.published_at).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
			<span class="brand-tag">Taka Sport</span>
		</footer>
	</article>
</Layout>