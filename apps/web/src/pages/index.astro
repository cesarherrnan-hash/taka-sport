---
export const prerender = false; // <--- LA MAGIA: Obliga a Vercel a cargar datos en vivo
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// Consultamos las noticias publicadas
const { data: posts } = await supabase
  .from('editorial_drafts')
  .select('*')
  .eq('status', 'published')
  .order('published_at', { ascending: false });
---

<Layout title="Taka Sport | Últimas Noticias Deportivas">
    <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="mb-10 border-l-4 border-red-600 pl-4">
            <h1 class="text-4xl md:text-5xl font-black uppercase italic tracking-wide text-white">
                Última <span class="text-red-600">Hora</span>
            </h1>
            <p class="text-gray-400 mt-2 text-lg">La actualidad deportiva mundial, filtrada y validada por nuestro panel.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts?.map((post) => (
                <article class="bg-gray-800 rounded-xl overflow-hidden shadow-lg border border-gray-700 hover:border-red-500 transition-all duration-300 flex flex-col group hover:-translate-y-1">
                    <div class="p-6 flex flex-col flex-grow">
                        <h2 class="text-xl font-bold text-white mb-3 leading-tight group-hover:text-red-400 transition-colors">
                            <a href={`/post/${post.slug}`}>
                                {post.title}
                            </a>
                        </h2>
                        <p class="text-gray-400 text-sm mb-6 flex-grow line-clamp-3">
                            {post.seo_description}
                        </p>
                        
                        <a href={`/post/${post.slug}`} class="block w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-4 rounded transition-colors text-center uppercase tracking-wider text-sm mt-auto">
                            Leer cobertura completa
                        </a>
                    </div>
                </article>
            ))}
        </div>
    </div>
</Layout>