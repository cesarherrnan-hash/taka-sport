---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import UpcomingMatches from '../components/UpcomingMatches.astro'; // <--- IMPORTAMOS EL CALENDARIO
import { supabase } from '../lib/supabase';

// 1. Capturamos etiquetas de noticias
const tag = Astro.url.searchParams.get('tag');

// 2. Consultamos Noticias
let newsQuery = supabase
  .from('editorial_drafts')
  .select('*')
  .eq('status', 'published')
  .order('published_at', { ascending: false });

if (tag) {
    newsQuery = newsQuery.eq('category', tag);
}

const { data: posts } = await newsQuery;

// 3. Consultamos REELS Automáticos
const { data: reels } = await supabase
  .from('instagram_reels')
  .select('*')
  .order('published_at', { ascending: false })
  .limit(10);
---

<Layout title={tag ? `Taka Sports | ${tag}` : "Taka Sports | Inicio"}>
	<style>
		.header-section { margin-bottom: 2rem; border-left: 4px solid var(--accent-red); padding-left: 1rem; }
		.main-title { font-size: 2.5rem; font-weight: 900; text-transform: uppercase; font-style: italic; color: white; }
		.logo-red { color: var(--accent-red); }
        .subtitle { color: var(--text-muted); font-size: 1.125rem; }

        .reels-section { margin-bottom: 3rem; }
        .reels-header { font-size: 1.2rem; font-weight: 900; text-transform: uppercase; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.8rem; color: white; }
        .live-dot { width: 10px; height: 10px; background: #22c55e; border-radius: 50%; box-shadow: 0 0 10px #22c55e; animation: pulse 2s infinite; }
        
        @keyframes pulse {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
        }

        .portal-layout { display: grid; grid-template-columns: 1fr; gap: 3rem; }
        @media (min-width: 1024px) {
            /* Damos un poco más de espacio a las noticias y fijamos la barra lateral */
            .portal-layout { grid-template-columns: 1fr 320px; align-items: start; }
            .sidebar { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 3rem; }
        }

		.news-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
		.card { background-color: rgba(31, 41, 55, 0.5); border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); padding: 1.5rem; display: flex; flex-direction: column; transition: 0.2s; backdrop-filter: blur(10px); }
		.card:hover { border-color: rgba(255,255,255,0.2); transform: translateY(-2px); }
		.category-badge { color: var(--accent-red); font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 0.5rem; letter-spacing: 0.05em; }
		.card-title { font-size: 1.3rem; font-weight: 700; color: white; margin-bottom: 0.75rem; line-height: 1.3;}
		.card-desc { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
		
        .empty-reels { padding: 2rem; background: var(--bg-card); border-radius: 12px; text-align: center; color: var(--text-muted); border: 1px dashed #374151; }
	</style>

	<div class="header-section">
		<h1 class="main-title">Noticias</h1>
		<p class="subtitle">Toda la actualidad deportiva en tiempo real.</p>
	</div>

    <section class="reels-section">
        <h3 class="reels-header"><div class="live-dot"></div> Taka <span class="logo-red">TV</span></h3>
        {reels && reels.length > 0 ? (
            <InstagramFeed reels={reels} />
        ) : (
            <div class="empty-reels">Esperando sincronización con Instagram...</div>
        )}
    </section>

    <div class="portal-layout">
        <div class="main-content">
            <div class="news-grid">
                {posts?.map((post) => (
                    <article class="card">
                        {post.category && <span class="category-badge">{post.category}</span>}
                        <h2 class="card-title">
                            <a href={`/post/${post.slug}`} style="text-decoration: none; color: inherit;">{post.title}</a>
                        </h2>
                        <p class="card-desc">{post.seo_description}</p>
                    </article>
                ))}
            </div>
        </div>

        <aside class="sidebar">
            <div style="background: rgba(88, 28, 135, 0.1); border: 1px solid rgba(147, 51, 234, 0.3); border-radius: 16px; padding: 1.5rem; text-align: center;">
                <h3 style="color: #c084fc; font-size: 1rem; font-weight: 800; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em;">⚽ Quiniela Activa</h3>
                <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;">Jornada 38 - LaLiga</p>
                <div style="background: rgba(147, 51, 234, 0.2); color: white; padding: 0.75rem; border-radius: 8px; font-weight: bold; font-size: 0.9rem; cursor: pointer; transition: 0.2s;" onmouseover="this.style.background='rgba(147, 51, 234, 0.4)'" onmouseout="this.style.background='rgba(147, 51, 234, 0.2)'">
                    HACER PREDICCIÓN →
                </div>
            </div>

            <UpcomingMatches />
        </aside>
    </div>
</Layout>