---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import { supabase } from '../lib/supabase';

const tag = Astro.url.searchParams.get('tag');

let query = supabase
  .from('editorial_drafts')
  .select('*')
  .eq('status', 'published')
  .order('published_at', { ascending: false });

if (tag) {
    query = query.eq('category', tag);
}

const { data: posts } = await query;

// ==========================================
// AQUÍ ES DONDE TÚ EDITARÁS TUS REELS
// ==========================================
const misReels = [
    {
        title: "Resumen Champions",
        link: "https://www.instagram.com/taka.sports/", 
        image: "https://images.unsplash.com/photo-1579952363873-27f3bade9f55?q=80&w=600&auto=format&fit=crop"
    },
    {
        title: "Match Point Alcaraz",
        link: "https://www.instagram.com/taka.sports/",
        image: "https://images.unsplash.com/photo-1541534741688-6078c6bfb5c5?q=80&w=600&auto=format&fit=crop"
    },
    {
        title: "Clavada Histórica",
        link: "https://www.instagram.com/taka.sports/",
        image: "https://images.unsplash.com/photo-1504450758481-7338eba7524a?q=80&w=600&auto=format&fit=crop"
    },
    {
        title: "F1 GP Mónaco",
        link: "https://www.instagram.com/taka.sports/",
        image: "https://images.unsplash.com/photo-1538332576228-eb5b4c4de6f5?q=80&w=600&auto=format&fit=crop"
    }
];
---

<Layout title={tag ? `Taka Sport | Noticias de ${tag}` : "Taka Sport | Portada"}>
	<style>
		.header-section { margin-bottom: 2rem; border-left: 4px solid var(--accent-red); padding-left: 1rem; }
		.main-title { font-size: 2.5rem; font-weight: 900; text-transform: uppercase; font-style: italic; color: white; }
		.logo-red { color: var(--accent-red); }
        .subtitle { color: var(--text-muted); font-size: 1.125rem; }

        .reels-section { margin-bottom: 3rem; }
        .reels-header { font-size: 1.2rem; font-weight: 900; text-transform: uppercase; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.8rem; color: white; }
        .live-dot { width: 10px; height: 10px; background: var(--accent-red); border-radius: 50%; box-shadow: 0 0 10px var(--accent-red); }

        .portal-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
        @media (min-width: 1024px) {
            .portal-layout { grid-template-columns: 1fr 350px; align-items: start; }
            .sidebar { position: sticky; top: 100px; }
        }

		.news-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
		.card { background-color: var(--bg-card); border-radius: 0.75rem; border: 1px solid #374151; padding: 1.5rem; display: flex; flex-direction: column; transition: 0.2s; }
		.card:hover { border-color: var(--accent-red); transform: translateY(-4px); }
		.category-badge { background-color: var(--accent-red); color: white; padding: 0.25rem 0.5rem; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; border-radius: 0.25rem; margin-bottom: 0.75rem; width: fit-content; }
		.card-title { font-size: 1.4rem; font-weight: 800; color: white; margin-bottom: 0.75rem; line-height: 1.2;}
		.card-desc { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
		.btn-read { display: block; background: var(--accent-red); color: white; text-align: center; padding: 0.8rem; border-radius: 0.5rem; font-weight: bold; text-transform: uppercase; font-size: 0.85rem; }

        .sidebar-title { font-size: 1.5rem; font-weight: 900; text-transform: uppercase; font-style: italic; margin-bottom: 1.5rem; border-bottom: 2px solid var(--accent-red); padding-bottom: 0.5rem; color: white; }
        .sidebar-box { background: var(--bg-card); border: 1px solid #374151; border-radius: 12px; padding: 1.5rem; text-align: center; }
        .sidebar-box p { color: var(--text-muted); margin-bottom: 1rem; }
        .btn-ig { display: inline-block; background: #E1306C; color: white; padding: 0.75rem 1.5rem; border-radius: 2rem; font-weight: bold; text-transform: uppercase; font-size: 0.85rem; }
	</style>

	<div class="header-section">
		<h1 class="main-title">Taka <span class="logo-red">News</span></h1>
		<p class="subtitle">Actualidad deportiva filtrada y validada por nuestro panel.</p>
	</div>

    <section class="reels-section">
        <h3 class="reels-header"><div class="live-dot"></div> Taka <span class="logo-red">Reels</span></h3>
        <InstagramFeed reels={misReels} />
    </section>

    <div class="portal-layout">
        <div class="main-content">
            <div class="news-grid">
                {posts?.map((post) => (
                    <article class="card">
                        {post.category && <span class="category-badge">{post.category}</span>}
                        <h2 class="card-title">
                            <a href={`/post/${post.slug}`}>{post.title}</a>
                        </h2>
                        <p class="card-desc">{post.seo_description}</p>
                        <a href={`/post/${post.slug}`} class="btn-read">Leer Cobertura Completa</a>
                    </article>
                ))}
            </div>
        </div>

        <aside class="sidebar">
            <h3 class="sidebar-title">Reel <span class="logo-red">Destacado</span></h3>
            
            <a href="https://www.instagram.com/taka.sports/" target="_blank" style="text-decoration: none;">
                <div class="sidebar-box" style="padding: 0; overflow: hidden; position: relative;">
                    <img src="https://images.unsplash.com/photo-1579952363873-27f3bade9f55?q=80&w=600&auto=format&fit=crop" alt="Destacado" style="width: 100%; height: 450px; object-fit: cover; display: block;" />
                    
                    <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.5); display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 2rem;">
                        <svg viewBox="0 0 24 24" fill="white" width="64" height="64" style="margin-bottom: 1rem;"><path d="M8 5.14v14l11-7-11-7z"/></svg>
                        <span class="btn-ig">Ver en Instagram</span>
                    </div>
                </div>
            </a>
        </aside>
    </div>
</Layout>